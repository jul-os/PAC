    "plt.imshow(heat_map_resize, cmap=\"hot\")\n",
    "plt.title(f\"Тепловая карта (max={heat_map.max():.1f})\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.subplot(1, 3, 3)\n",
    "plt.imshow(res)\n",
    "plt.title(\"Результат наложения\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Координаты максимума\n",
    "max_loc = np.where(heat_map_resize == heat_map_resize.max())\n",
    "print(f\"Найден центр: x={max_loc[1][0]}, y={max_loc[0][0]}\")"
