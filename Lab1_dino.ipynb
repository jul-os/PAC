    "import torch\n",
    "import torch.nn.functional as F\n",
    "import torchvision\n",
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "model = torchvision.models.resnet18(pretrained=True)\n",
    "model.eval()\n",
    "\n",
    "template_features = None\n",
    "layer4_features = None\n",
    "\n",
    "def get_template_hook(module, inputs, output):\n",
    "    global template_features\n",
    "    template_features = output\n",
    "\n",
    "def get_image_hook(module, inputs, output):\n",
    "    global layer4_features\n",
    "    layer4_features = output\n",
    "\n",
    "model.avgpool.register_forward_hook(get_template_hook)\n",
    "model.layer4.register_forward_hook(get_image_hook)\n",
    "\n",
    "preprocess = torchvision.transforms.Compose(\n",
    "    [\n",
    "        torchvision.transforms.ToPILImage(),\n",
    "        torchvision.transforms.ToTensor(),\n",
    "        torchvision.transforms.Normalize(\n",
    "            mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]\n",
    "        ),\n",
    "    ]\n",
    ")\n",
    "\n",
    "# --- 2. Подготовка данных ---\n",
    "# Шаблон (динозавр 'j')\n",
    "source = cv2.cvtColor(\n",
    "    cv2.imread(\"/home/julia/Рабочий стол/code/PAC/images/Labs/I/abc.png\"),\n",
    "    cv2.COLOR_BGR2RGB,\n",
    ")\n",
    "one = dinos_dict[\"j\"]\n",
    "our_dino = source[one[0] : one[1], one[2] : one[3]]\n",
    "\n",
    "# Целевое изображение\n",
    "test = cv2.cvtColor(\n",
    "    cv2.imread(\"/home/julia/Рабочий стол/code/PAC/images/Labs/I/abc.jpg\"),\n",
    "    cv2.COLOR_BGR2RGB,\n",
    ")\n",
    "\n",
    "# --- 3. Извлечение признаков ---\n",
    "# Признаки шаблона (через avgpool)\n",
    "input_tensor = preprocess(our_dino)\n",
    "with torch.no_grad():\n",
    "    model(input_tensor[None, :, :, :])\n",
    "# shape: [1, 512, 1, 1] -> [512]\n",
    "t_feat = template_features.squeeze()\n",
    "\n",
    "# Признаки изображения (через layer4)\n",
    "input_tensor = preprocess(test)\n",
    "with torch.no_grad():\n",
    "    model(input_tensor[None, :, :, :])\n",
    "# shape: [1, 512, H, W] -> [512, H, W]\n",
    "i_feat = layer4_features.squeeze()\n",
    "\n",
    "C, H, W = i_feat.shape\n",
    "\n",
    "# --- 4. Вычисление карты сходства (ИСПРАВЛЕНИЕ) ---\n",
    "\n",
    "# 1. Нормализуем вектор шаблона (один вектор)\n",
    "t_feat_norm = F.normalize(t_feat, p=2, dim=0)\n",
    "\n",
    "# 2. Нормализуем карту признаков по каналам (для каждого пикселя HxW отдельно)\n",
    "# Перемещаем каналы в начало для корректной нормализации по измерениям\n",
    "i_feat_norm = F.normalize(i_feat, p=2, dim=0)\n",
    "\n",
    "# 3. Косинусное сходство (скалярное произведение нормированных векторов)\n",
    "# t_feat_norm: [512]\n",
    "# i_feat_norm: [512, H, W]\n",
    "# Результат: [H, W]\n",
    "cos_sim = torch.sum(t_feat_norm[:, None, None] * i_feat_norm, dim=0)\n",
    "\n",
    "# 4. ВАЖНО: Умножаем на магнитуду (силу активации) признаков изображения\n",
    "# Это подавляет фон, так как на фоне активации слабые, даже если угол совпадает\n",
    "magnitude = torch.norm(i_feat, p=2, dim=0)\n",
    "heat_map = cos_sim * magnitude\n",
    "\n",
    "# 5. Перевод в numpy и нормализация для визуализации\n",
    "heat_map = heat_map.cpu().detach().numpy()\n",
    "\n",
    "# --- 5. Постобработка и визуализация ---\n",
    "\n",
    "# Обнуляем отрицательные значения (анти-корреляция нам не нужна)\n",
    "heat_map[heat_map < 0] = 0\n",
    "\n",
    "# Пороговая фильтрация (убираем слабый шум)\n",
    "threshold = heat_map.max() * 0.5  # Можно подобрать (0.3 - 0.7)\n",
    "heat_map[heat_map < threshold] = 0\n",
    "\n",
    "# Нормализация к 0-255\n",
    "if heat_map.max() > 0:\n",
    "    heat_map = (heat_map / heat_map.max()) * 255\n",
    "heat_map = heat_map.astype(np.uint8)\n",
    "\n",
    "# Ресайз под размер оригинального фото\n",
    "image_height, image_width = test.shape[:2]\n",
    "heat_map_resize = cv2.resize(heat_map, (image_width, image_height))\n",
    "\n",
    "# Наложение маски (COLORMAP_JET)\n",
